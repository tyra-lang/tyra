# bench/static-corpus/set_remove_test.tyra
# Tests Set.remove is non-destructive: original set is unaffected.
# SPEC_REF: §17.3.x (ADR-0015) — Set persistent semantics (v0.7.0)
import assert

fn test_set_remove_persistent() -> Result<Unit, String>
  let s: Set<Int> = set.new()
  let s = s.insert(1)
  let s = s.insert(2)
  let s = s.insert(3)
  let s2 = s.remove(1)
  assert.eq(s.contains(1), true)?
  assert.eq(s2.contains(1), false)?
  assert.eq(s.len(), 3)?
  assert.eq(s2.len(), 2)?
  Ok(())
end

fn test_set_remove_absent_is_noop() -> Result<Unit, String>
  let s: Set<Int> = set.new()
  let s = s.insert(10)
  let s2 = s.remove(99)
  assert.eq(s2.contains(10), true)?
  assert.eq(s2.len(), 1)?
  Ok(())
end
