# bench/static-corpus/math_test.tyra — smoke tests for basic arithmetic
# Run with: tyra test bench/static-corpus/math_test.tyra
import assert

fn test_addition() -> Result<Unit, String>
  assert.eq(1 + 1, 2)?
  assert.eq(10 + 5, 15)?
  assert.eq(0 + 0, 0)?
  Ok(())
end

fn test_subtraction() -> Result<Unit, String>
  assert.eq(10 - 3, 7)?
  assert.eq(5 - 5, 0)?
  Ok(())
end

fn test_multiplication() -> Result<Unit, String>
  assert.eq(3 * 4, 12)?
  assert.eq(0 * 100, 0)?
  Ok(())
end

fn test_division() -> Result<Unit, String>
  assert.eq(10 / 2, 5)?
  assert.eq(9 / 3, 3)?
  Ok(())
end

fn test_ne() -> Result<Unit, String>
  assert.ne(1, 2)?
  assert.ne(0, 1)?
  Ok(())
end
