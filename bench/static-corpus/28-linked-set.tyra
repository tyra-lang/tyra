# 28-linked-set.tyra
# Validates: LinkedSet insertion order, contains, remove, len (ADR-0019)
import linked_set

fn main() -> Unit
  let s: LinkedSet<String> = LinkedSet.new()
  let s = s.insert("x")
  let s = s.insert("y")
  let s = s.insert("z")
  print("len=#{s.len()}")
  print("has_x=#{s.contains("x")}")
  print("has_w=#{s.contains("w")}")
  for v in s
    print(v)
  end
  let s2 = s.remove("y")
  for v in s2
    print(v)
  end
end
