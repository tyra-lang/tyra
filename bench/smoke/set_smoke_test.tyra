fn test_set_int() -> Result<Unit, String>
  let s: Set<Int> = set.new()
  let s = s.insert(1)
  let s = s.insert(2)
  let s = s.insert(3)
  if s.len() != 3
    return Err("expected len 3, got #{s.len()}")
  end
  if s.contains(2) != true
    return Err("contains(2) should be true")
  end
  if s.contains(99) != false
    return Err("contains(99) should be false")
  end
  let s2 = s.insert(2)
  if s2.len() != 3
    return Err("duplicate insert should be idempotent")
  end
  Ok(())
end

fn test_set_string() -> Result<Unit, String>
  let s: Set<String> = set.new()
  let s = s.insert("apple")
  let s = s.insert("banana")
  let s = s.insert("cherry")
  if s.len() != 3
    return Err("expected len 3")
  end
  if s.contains("banana") != true
    return Err("contains banana should be true")
  end
  if s.contains("grape") != false
    return Err("contains grape should be false")
  end
  let s2 = s.insert("apple")
  if s2.len() != 3
    return Err("duplicate string insert should be idempotent")
  end
  Ok(())
end

fn test_set_empty() -> Result<Unit, String>
  let s: Set<Int> = set.new()
  if s.len() != 0
    return Err("empty set should have len 0")
  end
  if s.contains(42) != false
    return Err("empty set should not contain anything")
  end
  Ok(())
end

