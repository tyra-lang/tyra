{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "\\b(fn|if|else|while|for|match|when|impl|trait|value|data|type)\\b.*$",
    "decreaseIndentPattern": "^\\s*end\\b"
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
