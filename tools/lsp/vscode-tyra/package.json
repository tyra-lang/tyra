{
  "name": "vscode-tyra",
  "displayName": "Tyra",
  "description": "Tyra language support (syntax highlighting, diagnostics, hover types)",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:tyra"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "tyra",
        "aliases": [
          "Tyra",
          "tyra"
        ],
        "extensions": [
          ".tyra"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tyra",
        "scopeName": "source.tyra",
        "path": "./syntaxes/tyra.tmLanguage.json"
      }
    ],
    "breakpoints": [
      { "language": "tyra" }
    ],
    "debuggers": [
      {
        "type": "tyra",
        "label": "Tyra Debug (lldb)",
        "languages": ["tyra"],
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the compiled Tyra binary (build with `tyra build`)."
              },
              "args": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Command-line arguments passed to the program.",
                "default": []
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the debug session.",
                "default": "${workspaceFolder}"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Stop at program entry.",
                "default": false
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "tyra",
            "request": "launch",
            "name": "Debug Tyra program",
            "program": "${workspaceFolder}/out/my_program",
            "args": [],
            "cwd": "${workspaceFolder}"
          }
        ],
        "configurationSnippets": [
          {
            "label": "Tyra: Launch (lldb-dap)",
            "description": "Debug a compiled Tyra binary with lldb.",
            "body": {
              "type": "tyra",
              "request": "launch",
              "name": "${1:Debug Tyra program}",
              "program": "${workspaceFolder}/${2:out/program}",
              "args": [],
              "cwd": "${workspaceFolder}"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
